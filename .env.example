# Target chain (Ethereum Sepolia = 11155111)
VITE_TARGET_CHAIN_ID=11155111

# Public RPC for Helios verification + account state reads
VITE_EXECUTION_RPC_URL=

# Beacon API endpoint for Helios consensus (e.g. https://ethereum-sepolia-beacon-api.publicnode.com)
VITE_CONSENSUS_RPC_URL=

# ERC-4337 Bundler URL
VITE_BUNDLER_URL=

# Paymaster URL (optional — leave empty to pay gas from smart wallet ETH)
VITE_PAYMASTER_URL=

# --- Self-hosted contract addresses (set after forge script Deploy) ---

# PasskeyRegistry: maps credentialIdHash → AA wallet address (cross-service discovery)
VITE_PASSKEY_REGISTRY_ADDRESS=

# CoinbaseSmartWallet implementation (non-upgradeable)
VITE_SMART_WALLET_IMPL=

# CoinbaseSmartWalletFactory (LibClone.cloneDeterministic)
VITE_SMART_WALLET_FACTORY=

# DataStore (array-based, per-user entries with timestamps)
VITE_DATA_STORE_ADDRESS=

# ZeroDev project ID (bundler/paymaster — optional if using own infrastructure)
VITE_ZERODEV_PROJECT_ID=

# --- v2 contract addresses (set after forge script DeployENS / DeployVoting) ---

# MiniENS: maps name ↔ AA wallet address (identity layer)
VITE_MINI_ENS_ADDRESS=

# VotingRegistry: on-chain governance proposals and votes
VITE_VOTING_REGISTRY_ADDRESS=

# --- v3 contract addresses (set after forge script DeployVC) ---

# VCRegistry: DID/VC format registry, request/approve flow, on-chain hash anchoring
VITE_VC_REGISTRY_ADDRESS=
